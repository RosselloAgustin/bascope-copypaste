<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Speeches Vendedor — Bascope Jeans</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #13151f;
      min-height: 100vh;
      padding: 40px 16px 100px;
    }

    .header {
      text-align: center;
      margin-bottom: 36px;
    }
    .header h1 {
      font-size: 20px;
      font-weight: 700;
      color: #e8eaf0;
    }
    .header p {
      font-size: 13px;
      color: #555a72;
      margin-top: 4px;
    }

    .cards {
      max-width: 580px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .card {
      background: #1e2130;
      border: 1.5px solid #2e3248;
      border-radius: 16px;
      padding: 22px 22px 18px;
      cursor: pointer;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s, transform 0.15s;
      position: relative;
      user-select: none;
      box-shadow: 0 4px 16px rgba(0,0,0,0.35), 0 1px 3px rgba(0,0,0,0.25);
    }
    .card:hover {
      border-color: #4a5070;
      background: #232640;
      box-shadow: 0 8px 28px rgba(0,0,0,0.45), 0 2px 6px rgba(0,0,0,0.3);
      transform: translateY(-2px);
    }
    .card:active {
      transform: translateY(0px) scale(0.985);
    }
    .card.focused {
      border-color: #4db890;
      background: #1a2b28;
      box-shadow: 0 6px 28px rgba(60,180,130,0.2), 0 2px 8px rgba(60,180,130,0.12), 0 4px 16px rgba(0,0,0,0.4);
    }
    .card.focused:hover {
      box-shadow: 0 10px 36px rgba(60,180,130,0.28), 0 2px 8px rgba(60,180,130,0.15), 0 4px 20px rgba(0,0,0,0.45);
    }

    .badge {
      display: none;
      position: absolute;
      top: -11px;
      left: 18px;
      background: #4db890;
      color: #0d1f1a;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      padding: 3px 11px;
      border-radius: 20px;
    }
    .card.focused .badge { display: block; }

    .card-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #3a3f58;
      margin-bottom: 10px;
    }
    .card.focused .card-label { color: #4db890; }

    .card-text {
      font-size: 15px;
      line-height: 1.72;
      color: #c8cce0;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .card.focused .card-text { color: #e0f0ea; }

    .card-hint {
      margin-top: 14px;
      font-size: 12px;
      color: #353a52;
    }
    .card.focused .card-hint { color: #2d7a60; }

    /* Bottom action zone */
    .action-zone {
      max-width: 580px;
      margin: 24px auto 0;
      background: #1e2130;
      border: 1.5px solid #2e3248;
      border-radius: 16px;
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.35);
    }

    .action-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #3a3f58;
    }

    .action-row {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .btn-copy {
      flex: 1;
      min-width: 160px;
      background: #4db890;
      color: #0d1f1a;
      border: none;
      padding: 13px 20px;
      border-radius: 11px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 3px 12px rgba(60,180,130,0.25);
    }
    .btn-copy:hover {
      background: #5dcfa4;
      box-shadow: 0 5px 18px rgba(60,180,130,0.38);
    }
    .btn-copy:active { transform: scale(0.97); }

    .shortcut-box {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      background: #171928;
      border: 1.5px solid #272b40;
      border-radius: 11px;
      flex: 1;
      min-width: 140px;
    }
    .shortcut-box .icon { font-size: 18px; }
    .shortcut-box .info { display: flex; flex-direction: column; }
    .shortcut-box .info span {
      font-size: 12px;
      color: #555a72;
      line-height: 1.4;
    }
    .shortcut-box .info strong {
      font-size: 13px;
      color: #9ea3bc;
    }
    kbd {
      display: inline-block;
      background: #252840;
      border: 1px solid #3a3f58;
      border-radius: 5px;
      padding: 2px 7px;
      font-size: 12px;
      font-family: monospace;
      color: #9ea3bc;
      box-shadow: 0 2px 0 #0d0f18;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%) translateY(16px);
      background: #4db890;
      color: #0a1a15;
      padding: 11px 24px;
      border-radius: 30px;
      font-size: 14px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0;
      transition: opacity 0.22s ease, transform 0.22s ease;
      pointer-events: none;
      z-index: 999;
      white-space: nowrap;
      box-shadow: 0 4px 20px rgba(60,180,130,0.4);
    }
    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    /* Flash animation on card when copied */
    @keyframes flash {
      0%   { background: #1f3830; border-color: #6de0b0; }
      100% { background: #1a2b28; border-color: #4db890; }
    }
    .card.focused.flash { animation: flash 0.4s ease; }
  </style>
</head>
<body>

  <div class="header">
    <h1>💬 Speeches Vendedor</h1>
    <p>Bascope Jeans · Uso interno</p>
  </div>

  <div class="cards" id="cardsContainer"></div>

  <div class="action-zone">
    <div class="action-title">Opciones de copiado</div>
    <div class="action-row">
      <button class="btn-copy" id="btnCopy" onclick="copyFocused()">
        📋 Copiar texto sugerido
      </button>
      <div class="shortcut-box">
        <span class="icon">⌨️</span>
        <div class="info">
          <strong><kbd>Ctrl</kbd> + <kbd>C</kbd></strong>
          <span>Copia el speech sugerido al azar</span>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast">
    <span>✅</span>
    <span id="toastMsg">Copiado</span>
  </div>

  <script>
    const SPEECHES = [
      "Hola! 😊 Paso por acá porque me habías pedido información sobre nuestra indumentaria. Sumamos nuevos modelos que están geniales, te envío los catálogos actualizados.",
      "Hola! Paso por acá porque me habías pedido asesoramiento, estas disponible para que charlemos ?",
      "Hola! Me habias pedido el catálogo, queres que te de una mano o armamos un pedido?"
    ];

    let focusedIndex = 0;
    let queue = [];

    // ── Queue helpers ─────────────────────────────────────────────────────────

    function buildQueue(exclude = null) {
      let pool = SPEECHES.map((_, i) => i).filter(i => i !== exclude);
      // Fisher-Yates shuffle
      for (let i = pool.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [pool[i], pool[j]] = [pool[j], pool[i]];
      }
      queue = pool;
    }

    function nextFromQueue(exclude = null) {
      if (queue.length === 0) buildQueue(exclude);
      return queue.shift();
    }

    // ── Render ────────────────────────────────────────────────────────────────

    function render() {
      const container = document.getElementById('cardsContainer');
      container.innerHTML = '';
      SPEECHES.forEach((text, i) => {
        const isFocused = i === focusedIndex;
        const card = document.createElement('div');
        card.className = 'card' + (isFocused ? ' focused' : '');
        card.id = 'card-' + i;
        card.innerHTML = `
          <div class="badge">Sugerido</div>
          <div class="card-label">Speech ${i + 1}</div>
          <div class="card-text">${escHtml(text)}</div>
          <div class="card-hint">${isFocused ? 'Este es el sugerido — Ctrl+C o botón de abajo' : 'Clic para copiar este específicamente'}</div>
        `;
        card.addEventListener('click', () => onCardClick(i));
        container.appendChild(card);
      });
    }

    function escHtml(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    // ── Copy actions ──────────────────────────────────────────────────────────

    function doCopy(index) {
      return navigator.clipboard.writeText(SPEECHES[index]).then(() => {
        buildQueue(index);
        focusedIndex = nextFromQueue(index);
        render();
        // flash the card that was just copied
        const prevCard = document.getElementById('card-' + index);
        if (prevCard) {
          prevCard.classList.add('flash');
          setTimeout(() => prevCard.classList.remove('flash'), 400);
        }
        showToast(`Speech ${index + 1} copiado ✅`);
      });
    }

    function onCardClick(index) {
      doCopy(index);
    }

    function copyFocused() {
      doCopy(focusedIndex);
    }

    // ── Ctrl+C intercept ──────────────────────────────────────────────────────
    // Only intercepts when no text is selected on the page.

    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.key === 'c') {
        const sel = window.getSelection().toString();
        if (sel.length > 0) return; // let the browser handle normal text copy
        e.preventDefault();
        doCopy(focusedIndex);
      }
    });

    // ── Toast ─────────────────────────────────────────────────────────────────

    let toastTimer = null;
    function showToast(msg) {
      const toast = document.getElementById('toast');
      document.getElementById('toastMsg').textContent = msg;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('show'), 2400);
    }

    // ── Init ──────────────────────────────────────────────────────────────────

    buildQueue();
    focusedIndex = nextFromQueue();
    render();
  </script>
</body>
</html>
